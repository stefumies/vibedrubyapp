#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

mkdir -p tmp
pid_file=tmp/dev.pids

cleanup() {
  trap - EXIT INT TERM

  for pid in "${guard_pid:-}" "${rerun_pid:-}" "${banner_pid:-}"; do
    if [[ -n "${pid:-}" ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
  done

  wait "${guard_pid:-}" 2>/dev/null || true
  wait "${rerun_pid:-}" 2>/dev/null || true
  wait "${banner_pid:-}" 2>/dev/null || true
  rm -f "$pid_file"
}

trap 'cleanup; exit 0' INT TERM
trap cleanup EXIT

./bin/stop >/dev/null 2>&1 || true

bundle exec guard --no-interactions --watchdir . &
guard_pid=$!
bundle exec rerun --background --no-notify --ignore 'welcome.db' -- ruby app.rb &
rerun_pid=$!
printf '%s\n%s\n' "$guard_pid" "$rerun_pid" > "$pid_file"

(
  sleep 1
  printf '%s\n' "App: http://localhost:4567"
  printf '%s\n' "LiveReload: http://127.0.0.1:35729"
  printf '%s\n' "Stop: ./bin/stop or Ctrl-C"
) &
banner_pid=$!

status=0
wait -n "$guard_pid" "$rerun_pid" || status=$?
exit "$status"
