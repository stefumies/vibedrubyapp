#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

pid_file=tmp/dev.pids
stopped=0

stop_pid() {
  local pid=$1

  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null || return 1
  kill "$pid" 2>/dev/null || true
}

if [[ -f "$pid_file" ]]; then
  while IFS= read -r pid; do
    if stop_pid "$pid"; then
      stopped=1
    fi
  done < "$pid_file"
fi

rm -f "$pid_file"

for pattern in \
  'bundle exec guard --no-interactions --watchdir .' \
  'bundle exec rerun --background --no-notify --ignore welcome.db -- ruby app.rb' \
  'ruby app.rb'; do
  if pgrep -f "$pattern" >/dev/null 2>&1; then
    pkill -f "$pattern" 2>/dev/null || true
    stopped=1
  fi
done

if ((stopped)); then
  echo "Stopped dev processes."
else
  echo "No matching dev processes found."
  exit 1
fi
